*.py[cod]
*.egg-info/
.venv/
venv/
.env

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Data & outputs (keep folders via .gitkeep)
data/raw/*
data/processed/*
data/warehouse/*
