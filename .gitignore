!data/processed/.gitkeep
!data/warehouse/.gitkeep

outputs/reconciliation/*
outputs/exceptions/*
outputs/reports/*
!outputs/reconciliation/.gitkeep
!outputs/exceptions/.gitkeep
!outputs/reports/.gitkeep

# Logs
*.log

# Power BI temp
*.pbix.bak
